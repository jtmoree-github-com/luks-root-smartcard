#!/bin/sh
set -eu

PREREQ=""

prereqs() {
  echo "$PREREQ"
}

case "${1:-}" in
  prereqs)
    prereqs
    exit 0
    ;;
esac

. /scripts/functions

DEBUG_ENABLED=0
for _dbg_tok in $(cat /proc/cmdline 2>/dev/null); do
  case "$_dbg_tok" in
    rd.debug*) DEBUG_ENABLED=1; break ;;
  esac
done

msg() { echo "smartcard-root-tpm2: $*" >&2; }
dbg() {
  [ "$DEBUG_ENABLED" = "1" ] || return 0
  echo "smartcard-root-tpm2: DEBUG: $*" >&2
}

get_root_mapper_name() {
  for tok in $(cat /proc/cmdline); do
    case "$tok" in root=/dev/mapper/*) echo "${tok#root=/dev/mapper/}"; return 0 ;; esac
  done
  echo ""
}

resolve_mapping() {
  preferred_target="$1"
  found_target=""
  found_source=""
  found_key=""

  [ -r /cryptroot/crypttab ] || panic "smartcard-root-tpm2: /cryptroot/crypttab missing"

  while IFS= read -r line; do
    case "$line" in ''|'#'*) continue ;; esac
    set -- $line
    [ "$#" -ge 3 ] || continue
    if [ -n "$preferred_target" ]; then
      [ "$1" = "$preferred_target" ] || continue
    fi
    if [ -z "$found_target" ]; then
      found_target="$1"; found_source="$2"; found_key="$3"
      [ -n "$preferred_target" ] && break
    fi
  done </cryptroot/crypttab

  [ -n "$found_target" ] || panic "smartcard-root-tpm2: no usable mapping found in /cryptroot/crypttab"
  printf '%s|%s|%s\n' "$found_target" "$found_source" "$found_key"
}

resolve_device() {
  case "$1" in
    UUID=*)     blkid -U "${1#UUID=}" 2>/dev/null ;;
    LABEL=*)    blkid -L "${1#LABEL=}" 2>/dev/null ;;
    PARTUUID=*) echo "/dev/disk/by-partuuid/${1#PARTUUID=}" ;;
    PARTLABEL=*) echo "/dev/disk/by-partlabel/${1#PARTLABEL=}" ;;
    *)          echo "$1" ;;
  esac
}

auto_detect_tpm2_token() {
  _dev="$1"
  _i=0
  while [ "$_i" -lt 32 ]; do
    _json="$(cryptsetup token export --token-id "$_i" "$_dev" 2>/dev/null || true)"
    if [ -n "$_json" ]; then
      _type="$(printf '%s' "$_json" | tr -d '\n' | sed -n 's/.*"type":"\([^"]*\)".*/\1/p')"
      dbg "token $_i type=${_type:-unknown}"
      if [ "$_type" = "systemd-tpm2" ]; then
        echo "$_i"
        return 0
      fi
    fi
    _i=$(( _i + 1 ))
  done
  return 1
}

find_tpm_plugin_dir() {
  for _dir in /usr/lib/*/cryptsetup /usr/lib64/cryptsetup; do
    [ -f "$_dir/libcryptsetup-token-systemd-tpm2.so" ] || continue
    echo "$_dir"
    return 0
  done
  return 1
}

wait_for_tpm_device() {
  _try=0
  while [ "$_try" -lt 10 ]; do
    for _node in /dev/tpmrm[0-9]* /dev/tpm[0-9]*; do
      [ -c "$_node" ] || continue
      dbg "found TPM device: $_node"
      return 0
    done
    _try=$(( _try + 1 ))
    dbg "waiting for TPM device ($_try/10)"
    sleep 1
  done
  return 1
}

mapping="$(resolve_mapping "$(get_root_mapper_name)")"
CRYPTROOT_NAME="${mapping%%|*}"
rest="${mapping#*|}"
CRYPTROOT_SOURCE="${rest%%|*}"
KEY_SPEC="${rest#*|}"

dbg "mapping name=$CRYPTROOT_NAME source=$CRYPTROOT_SOURCE key-spec=${KEY_SPEC:-<empty>}"

if cryptsetup status "$CRYPTROOT_NAME" >/dev/null 2>&1; then
  dbg "mapping $CRYPTROOT_NAME already active"
  exit 0
fi

DEV="$(resolve_device "$CRYPTROOT_SOURCE")" || panic "smartcard-root-tpm2: cannot resolve device $CRYPTROOT_SOURCE"
[ -b "$DEV" ] || panic "smartcard-root-tpm2: $DEV is not a block device"
dbg "resolved backing device: $DEV"

TOKEN_ID="$(auto_detect_tpm2_token "$DEV" || true)"
if [ -z "$TOKEN_ID" ]; then
  dbg "no systemd-tpm2 token found on root device; exiting TPM2 path"
  exit 0
fi
msg "auto-detected token selector: systemd-tpm2:$TOKEN_ID"

PLUGIN_DIR="$(find_tpm_plugin_dir || true)"
if [ -z "$PLUGIN_DIR" ]; then
  msg "TPM2 token plugin not present in initramfs; continuing to standard cryptroot fallback"
  exit 0
fi

if ! wait_for_tpm_device; then
  msg "TPM2 device not detected; continuing to standard cryptroot fallback"
  exit 0
fi

if cryptsetup luksOpen \
    --token-only \
    --token-type systemd-tpm2 \
    --token-id "$TOKEN_ID" \
    --external-tokens-path "$PLUGIN_DIR" \
    "$DEV" "$CRYPTROOT_NAME"; then
  dbg "cryptsetup luksOpen succeeded via TPM2 token"
  exit 0
fi

msg "TPM2 unlock failed; continuing to standard cryptroot fallback"
exit 0
