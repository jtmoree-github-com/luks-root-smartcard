#!/bin/sh
set -eu

PREREQ=""

prereqs() {
  echo "$PREREQ"
}

case "${1:-}" in
  prereqs)
    prereqs
    exit 0
    ;;
esac

. /scripts/functions

DEBUG_ENABLED=0
for _dbg_tok in $(cat /proc/cmdline 2>/dev/null); do
  case "$_dbg_tok" in
    rd.debug*) DEBUG_ENABLED=1; break ;;
  esac
done

msg() { echo "smartcard-root-tpm2: $*" >&2; }
dbg() {
  [ "$DEBUG_ENABLED" = "1" ] || return 0
  echo "smartcard-root-tpm2: DEBUG: $*" >&2
}

# Early exit if crypttab field 3 is not 'none'.
# TPM2 tokens are discovered automatically from the LUKS2 header.
# If field 3 is a key file, leave stock cryptroot handling alone.
_early_keyspec=""
if [ -r /cryptroot/crypttab ]; then
  _early_mapper=""
  for _tok in $(cat /proc/cmdline 2>/dev/null); do
    case "$_tok" in root=/dev/mapper/*) _early_mapper="${_tok#root=/dev/mapper/}" ;; esac
  done
  while IFS= read -r _early_line; do
    case "$_early_line" in ''|'#'*) continue ;; esac
    set -- $_early_line
    [ "$#" -ge 3 ] || continue
    if [ -z "$_early_mapper" ] || [ "$1" = "$_early_mapper" ]; then
      _early_keyspec="$3"; break
    fi
  done </cryptroot/crypttab
fi
case "${_early_keyspec:-none}" in
  none) ;;
  *)
    dbg "key spec ${_early_keyspec} is not 'none'; exiting TPM2 path"
    exit 0
    ;;
esac

get_root_mapper_name() {
  for tok in $(cat /proc/cmdline); do
    case "$tok" in
      root=/dev/mapper/*) echo "${tok#root=/dev/mapper/}"; return 0 ;;
    esac
  done
  echo ""
}

resolve_mapping() {
  preferred_target="$1"
  found_target=""
  found_source=""
  found_key=""

  [ -r /cryptroot/crypttab ] || panic "smartcard-root-tpm2: /cryptroot/crypttab missing"

  while IFS= read -r line; do
    case "$line" in ''|'#'*) continue ;; esac
    set -- $line
    [ "$#" -ge 3 ] || continue
    if [ -n "$preferred_target" ]; then
      [ "$1" = "$preferred_target" ] || continue
    fi
    if [ -z "$found_target" ]; then
      found_target="$1"; found_source="$2"; found_key="$3"
      [ -n "$preferred_target" ] && break
    fi
  done </cryptroot/crypttab

  [ -n "$found_target" ] || panic "smartcard-root-tpm2: no usable mapping found in /cryptroot/crypttab"
  printf '%s|%s|%s\n' "$found_target" "$found_source" "$found_key"
}

resolve_device() {
  case "$1" in
    UUID=*)     blkid -U "${1#UUID=}" 2>/dev/null ;;
    LABEL=*)    blkid -L "${1#LABEL=}" 2>/dev/null ;;
    PARTUUID=*) echo "/dev/disk/by-partuuid/${1#PARTUUID=}" ;;
    PARTLABEL=*) echo "/dev/disk/by-partlabel/${1#PARTLABEL=}" ;;
    *)          echo "$1" ;;
  esac
}

# Parse a JSON string field: "key":"value"
json_value() {
  _jv_json="$1"
  _jv_key="$2"
  _jv_flat="$(printf '%s' "$_jv_json" | tr -d '\n')"
  _jv_after="${_jv_flat#*\"${_jv_key}\":\"}"
  [ "$_jv_after" != "$_jv_flat" ] || return 1
  _jv_val="${_jv_after%%\"*}"
  printf '%s' "$_jv_val"
}

# Parse a JSON integer field: "key": 7
json_int_value() {
  _jv_json="$1"
  _jv_key="$2"
  _jv_flat="$(printf '%s' "$_jv_json" | tr -d '\n')"
  _jv_after="${_jv_flat#*\"${_jv_key}\":}"
  [ "$_jv_after" != "$_jv_flat" ] || return 1
  _jv_after="${_jv_after# }"
  _jv_val="${_jv_after%%[^0-9]*}"
  [ -n "$_jv_val" ] || return 1
  printf '%s' "$_jv_val"
}

# Parse a JSON boolean field: "key": true|false
json_bool_value() {
  _jv_json="$1"
  _jv_key="$2"
  _jv_flat="$(printf '%s' "$_jv_json" | tr -d '\n')"
  _jv_after="${_jv_flat#*\"${_jv_key}\":}"
  [ "$_jv_after" != "$_jv_flat" ] || return 1
  _jv_after="${_jv_after# }"
  case "$_jv_after" in
    true*)  printf 'true'  ;;
    false*) printf 'false' ;;
    *)      return 1       ;;
  esac
}

# Convert a PCR bitmask integer to a comma-separated index list.
# e.g. 7 (0b111) -> "0,1,2"
pcr_mask_to_list() {
  _m="$(printf '%d' "${1:-0}" 2>/dev/null)" || return 1
  _list=""
  _i=0
  while [ "$_m" -gt 0 ]; do
    if [ $(( _m & 1 )) -eq 1 ]; then
      _list="${_list:+$_list,}$_i"
    fi
    _m=$(( _m >> 1 ))
    _i=$(( _i + 1 ))
  done
  printf '%s' "$_list"
}

# Split a combined TPM2B_PUBLIC || TPM2B_PRIVATE blob into separate files.
# Each TPM2B is: 2-byte big-endian size + payload.
split_tpm2_blob() {
  _blob="$1"
  _pub_out="$2"
  _priv_out="$3"

  _hex2="$(dd if="$_blob" bs=1 count=2 2>/dev/null | od -An -tx1 | tr -d ' \n')"
  _b1_dec="$(printf '%d' "0x${_hex2%??}")"
  _b2_dec="$(printf '%d' "0x${_hex2#??}")"
  _pub_sz=$(( _b1_dec * 256 + _b2_dec ))
  _pub_total=$(( _pub_sz + 2 ))

  dbg "tpm2 blob: public size=${_pub_sz}, total public bytes=${_pub_total}"

  dd if="$_blob" bs=1 count="$_pub_total" of="$_pub_out" 2>/dev/null
  dd if="$_blob" bs=1 skip="$_pub_total" of="$_priv_out" 2>/dev/null
}

tpm_device() {
  for _d in /dev/tpmrm0 /dev/tpmrm1 /dev/tpm0 /dev/tpm1; do
    [ -c "$_d" ] && echo "$_d" && return 0
  done
  return 1
}

auto_detect_tpm2_token() {
  _dev="$1"
  _i=0
  while [ "$_i" -lt 32 ]; do
    _json="$(cryptsetup token export --token-id "$_i" "$_dev" 2>/dev/null || true)"
    if [ -n "$_json" ]; then
      _t="$(json_value "$_json" "type" || true)"
      dbg "token $_i type=${_t:-unknown}"
      if [ "$_t" = "systemd-tpm2" ]; then
        echo "systemd-tpm2:$_i"
        return 0
      fi
    fi
    _i=$(( _i + 1 ))
  done
  return 1
}

unseal_tpm2() {
  _dev="$1"
  _selector="$2"
  _outkey="$3"

  _token_id="${_selector#*:}"

  _json="$(cryptsetup token export --token-id "$_token_id" "$_dev" 2>/dev/null || true)"
  [ -n "$_json" ] || { dbg "failed to export token $_token_id"; return 1; }

  # Validate token type
  _t="$(json_value "$_json" "type" || true)"
  [ "$_t" = "systemd-tpm2" ] || { dbg "token type is '$_t', not systemd-tpm2"; return 1; }

  # Required: encrypted key blob
  _blob_b64="$(json_value "$_json" "tpm2-blob" || true)"
  [ -n "$_blob_b64" ] || { dbg "tpm2-blob field missing"; return 1; }

  # PCR binding (integer bitmask; try int then string fallback; default 0 = no binding)
  _pcrs="$(json_int_value "$_json" "tpm2-pcrs" 2>/dev/null \
         || json_value "$_json" "tpm2-pcrs" 2>/dev/null \
         || echo "0")"
  _pcr_bank="$(json_value "$_json" "tpm2-pcr-bank" 2>/dev/null || echo "sha256")"

  # Primary key algorithm (ecc or rsa)
  _primary_alg="$(json_value "$_json" "tpm2-primary-alg" 2>/dev/null || echo "ecc")"

  # Whether a PIN is required to unseal (not currently supported)
  _pin="$(json_bool_value "$_json" "tpm2-pin" 2>/dev/null || echo "false")"

  # Optional persistent SRK handle stored at enrollment time
  _srk="$(json_int_value "$_json" "tpm2-srk" 2>/dev/null || echo "")"

  dbg "token $_token_id: pcrs=$_pcrs bank=$_pcr_bank primary=$_primary_alg pin=$_pin srk=${_srk:-none}"

  if [ "$_pin" = "true" ]; then
    msg "token requires a PIN (tpm2-pin) which is not supported; skipping"
    return 1
  fi

  # Resolve TPM device
  _tpm_dev="$(tpm_device)" || { msg "no TPM2 device found"; return 1; }
  export TPM2TOOLS_TCTI="device:$_tpm_dev"
  dbg "using TPM2 device: $_tpm_dev"

  _tdir="$(mktemp -d /run/tpm2.XXXXXX)"
  chmod 700 "$_tdir"

  # Decode base64 blob
  if ! printf '%s' "$_blob_b64" | base64 -d > "$_tdir/blob.bin" 2>/dev/null; then
    if ! printf '%s\n' "$_blob_b64" > "$_tdir/b64.tmp" && \
         base64 -d < "$_tdir/b64.tmp" > "$_tdir/blob.bin" 2>/dev/null; then
      dbg "failed to base64-decode tpm2-blob"
      rm -rf "$_tdir"; return 1
    fi
  fi

  # Split blob: TPM2B_PUBLIC (2-byte size + payload) || TPM2B_PRIVATE (same)
  split_tpm2_blob "$_tdir/blob.bin" "$_tdir/pub.bin" "$_tdir/priv.bin"

  [ -s "$_tdir/pub.bin" ] || { dbg "public portion is empty after split"; rm -rf "$_tdir"; return 1; }
  [ -s "$_tdir/priv.bin" ] || { dbg "private portion is empty after split"; rm -rf "$_tdir"; return 1; }

  # Determine parent context.
  # Prefer the persistent SRK handle that systemd stored at enrollment time.
  # Fall back to recreating the primary in the Owner hierarchy using the
  # standard TCG SRK template (deterministic: same seed + same template = same key).
  _prim_ctx="$_tdir/primary.ctx"
  _used_persistent=false

  if [ -n "$_srk" ] && [ "$_srk" -gt 0 ] 2>/dev/null; then
    _srk_hex="$(printf '0x%x' "$_srk")"
    if tpm2_readpublic -c "$_srk_hex" >/dev/null 2>"$_tdir/srk.log"; then
      _prim_ctx="$_srk_hex"
      _used_persistent=true
      dbg "using persistent SRK at $_srk_hex"
    else
      dbg "persistent SRK $_srk_hex not readable ($(cat "$_tdir/srk.log" 2>/dev/null | head -1)); recreating"
    fi
  fi

  if [ "$_used_persistent" = false ]; then
    case "$_primary_alg" in
      ecc*) _prim_alg_arg="ecc256:aes128cfb" ;;
      rsa*) _prim_alg_arg="rsa2048:aes128cfb" ;;
      *)    _prim_alg_arg="ecc256:aes128cfb" ;;
    esac
    dbg "creating SRK primary: hierarchy=o algorithm=$_prim_alg_arg"
    if ! tpm2_createprimary -C o -G "$_prim_alg_arg" \
        -a 'fixedtpm|fixedparent|sensitivedataorigin|userwithauth|noda|restricted|decrypt' \
        -c "$_prim_ctx" >"$_tdir/primary.log" 2>&1; then
      dbg "tpm2_createprimary failed: $(head -1 "$_tdir/primary.log" 2>/dev/null)"
      rm -rf "$_tdir"; return 1
    fi
    tpm2_flushcontext -t >/dev/null 2>&1 || true
  fi

  # Load the sealed object under the primary
  if ! tpm2_load -C "$_prim_ctx" \
      -u "$_tdir/pub.bin" \
      -r "$_tdir/priv.bin" \
      -c "$_tdir/sealed.ctx" >"$_tdir/load.log" 2>&1; then
    dbg "tpm2_load failed: $(head -1 "$_tdir/load.log" 2>/dev/null)"
    tpm2_flushcontext -t >/dev/null 2>&1 || true
    rm -rf "$_tdir"; return 1
  fi
  tpm2_flushcontext -t >/dev/null 2>&1 || true

  # Build PCR authorization and unseal
  _pcr_list="$(pcr_mask_to_list "$_pcrs" || echo "")"
  dbg "PCR mask=$_pcrs -> list='${_pcr_list:-<none>}'"

  if [ -n "$_pcr_list" ]; then
    _pcr_auth="${_pcr_bank}:${_pcr_list}"
    dbg "unsealing with PCR policy: pcr:$_pcr_auth"
    if ! tpm2_unseal -c "$_tdir/sealed.ctx" \
        -p "pcr:$_pcr_auth" \
        -o "$_outkey" >"$_tdir/unseal.log" 2>&1; then
      dbg "tpm2_unseal failed: $(head -1 "$_tdir/unseal.log" 2>/dev/null)"
      tpm2_flushcontext -t >/dev/null 2>&1 || true
      rm -rf "$_tdir"; return 1
    fi
  else
    dbg "unsealing with no PCR policy (pcrs=0)"
    if ! tpm2_unseal -c "$_tdir/sealed.ctx" \
        -o "$_outkey" >"$_tdir/unseal.log" 2>&1; then
      dbg "tpm2_unseal (no pcr) failed: $(head -1 "$_tdir/unseal.log" 2>/dev/null)"
      tpm2_flushcontext -t >/dev/null 2>&1 || true
      rm -rf "$_tdir"; return 1
    fi
  fi
  tpm2_flushcontext -t >/dev/null 2>&1 || true

  rm -rf "$_tdir"
  dbg "tpm2 unseal succeeded"
  return 0
}

prompt_skip_or_wait() {
  if [ -f /run/smartcard-skip-requested ]; then
    return 0
  fi

  echo "TPM2 unlock failed. Skip TPM2 and continue with passphrase fallback? [Y/n]" >&2
  read ANSWER
  case "${ANSWER:-Y}" in
    y|Y|"")
      : >/run/smartcard-skip-requested
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

# --- main ---

mapping="$(resolve_mapping "$(get_root_mapper_name)")"
CRYPTROOT_NAME="${mapping%%|*}"
rest="${mapping#*|}"
CRYPTROOT_SOURCE="${rest%%|*}"
KEY_SPEC="${rest#*|}"

dbg "mapping name=$CRYPTROOT_NAME source=$CRYPTROOT_SOURCE key-spec=${KEY_SPEC:-<empty>}"

if cryptsetup status "$CRYPTROOT_NAME" >/dev/null 2>&1; then
  dbg "mapping $CRYPTROOT_NAME already active"
  exit 0
fi

[ -n "$KEY_SPEC" ] || KEY_SPEC="none"

DEV="$(resolve_device "$CRYPTROOT_SOURCE")" || panic "smartcard-root-tpm2: cannot resolve device $CRYPTROOT_SOURCE"
[ -b "$DEV" ] || panic "smartcard-root-tpm2: $DEV is not a block device"
dbg "resolved backing device: $DEV"

# Only handle TPM2 tokens when crypttab field 3 is 'none'.
if [ "$KEY_SPEC" = "none" ]; then
  dbg "crypttab field 3 is none; scanning tokens for systemd-tpm2"
  KEY_SPEC="$(auto_detect_tpm2_token "$DEV" || true)"
  if [ -z "$KEY_SPEC" ]; then
    dbg "no systemd-tpm2 token found; leaving TPM2 path"
    exit 0
  fi
  msg "auto-detected token selector: $KEY_SPEC"
else
  dbg "key spec $KEY_SPEC is not 'none'; exiting TPM2 path"
  exit 0
fi

TMP_KEY="$(mktemp /run/smartcard-key.XXXXXX)"
chmod 600 "$TMP_KEY"
unlock_ok=false

if unseal_tpm2 "$DEV" "$KEY_SPEC" "$TMP_KEY"; then
  dbg "tpm2 unseal succeeded; attempting luksOpen"
  if cryptsetup luksOpen "$DEV" "$CRYPTROOT_NAME" --key-file "$TMP_KEY"; then
    unlock_ok=true
    dbg "cryptsetup luksOpen succeeded via TPM2"
  else
    dbg "cryptsetup luksOpen failed after successful TPM2 unseal"
  fi
else
  dbg "tpm2 unseal failed for selector $KEY_SPEC"
fi

rm -f "$TMP_KEY"

if [ "$unlock_ok" = true ]; then
  exit 0
fi

msg "TPM2 unlock failed"
if prompt_skip_or_wait; then
  msg "bypassing TPM2; continuing to standard cryptroot fallback"
  exit 0
fi
msg "TPM2 flow did not unlock root; continuing to standard cryptroot fallback"
exit 0
